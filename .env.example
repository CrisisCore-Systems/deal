# Enabled site adapters (comma separated): govplanet,publicsurplus,govdeals
ENABLED_SITES=govplanet,publicsurplus,govdeals

# Polling filters
ALERT_WINDOW_MIN=30
MAX_BIDS=0
MAX_CURRENT_BID=500

# Site URLs (adjust to your preferred 'ending soon' query pages)
GOVPLANET_LISTING_URL=https://www.govplanet.com/Government+Surplus
PUBLICSURPLUS_LISTING_URL=https://www.publicsurplus.com/sms/browse/home
GOVDEALS_LISTING_URL=https://www.govdeals.com/en

# Local alert cache
CACHE_DB_PATH=auction_watcher.db

# Optional notification webhook (if blank, prints to stdout)
DISCORD_WEBHOOK_URL=
